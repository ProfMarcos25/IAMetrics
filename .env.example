# ============================================================
# ARQUIVO DE EXEMPLO DE VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha com seus dados reais
# NÃO commite o arquivo .env no repositório!
# ============================================================

# ── Banco de Dados PostgreSQL ─────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_banco
DB_URL=postgresql://postgres:sua_senha@localhost:5432/frequencia_escolar

# ── Twilio (envio de SMS / WhatsApp) ─────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_NUMERO_ORIGEM=+55119XXXXXXXX

# ── Telegram Bot ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=0000000000:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Configurações Gerais do Sistema ──────────────────────
UNIDADE_ESCOLAR=Escola Estadual Jardim Iguatemi
# Intervalo mínimo (em minutos) entre dois registros do mesmo aluno
INTERVALO_DUPLICIDADE_MINUTOS=30
